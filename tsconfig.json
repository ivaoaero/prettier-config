{
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "moduleResolution": "nodenext",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist"],
  "include": ["src"]
}
