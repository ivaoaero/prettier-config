{
  "name": "@ivao/prettier-config",
  "description": "IVAO prettier config",
  "version": "0.0.0",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generateImportOrder": {
      "types": "./dist/generateImportOrder.d.ts",
      "default": "./dist/generateImportOrder.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ivaoaero/prettier-config.git"
  },
  "author": {
    "name": "IVAO",
    "url": "https://ivao.aero"
  },
  "contributors": [
    {
      "name": "Jonas Bellmann (533870)",
      "email": "jonas.bellmann@ivao.aero",
      "url": "https://github.com/CptnJon"
    }
  ],
  "maintainers": [
    {
      "name": "Jonas Bellmann (533870)",
      "email": "jonas.bellmann@ivao.aero",
      "url": "https://github.com/CptnJon"
    }
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --cache --report-unused-disable-directives --max-warnings 0",
    "lint-fix": "eslint . --cache --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier . --write --cache",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@ivao/eslint-config": "3.0.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@types/node": "24.12.2",
    "eslint": "10.2.1",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "~0.7.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
