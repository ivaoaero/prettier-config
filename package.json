{
  "name": "@ivao/prettier-config",
  "description": "IVAO prettier config",
  "version": "0.0.0",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generateImportOrder": {
      "types": "./dist/generateImportOrder.d.ts",
      "default": "./dist/generateImportOrder.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ivaoaero/prettier-config.git"
  },
  "author": {
    "name": "IVAO",
    "url": "https://ivao.aero"
  },
  "contributors": [
    {
      "name": "Jonas Bellmann (533870)",
      "email": "jonas.bellmann@ivao.aero",
      "url": "https://github.com/CptnJon"
    }
  ],
  "maintainers": [
    {
      "name": "Jonas Bellmann (533870)",
      "email": "jonas.bellmann@ivao.aero",
      "url": "https://github.com/CptnJon"
    }
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --cache --report-unused-disable-directives --max-warnings 0",
    "lint-fix": "eslint . --cache --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier . --write --cache",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@commitlint/types": "19.8.1",
    "@ivao/eslint-config": "2.0.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.2",
    "@semantic-release/npm": "13.1.3",
    "@types/node": "24.5.2",
    "eslint": "9.36.0",
    "semantic-release": "25.0.2",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.0",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
